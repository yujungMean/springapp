<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.app.springapp.mapper.PostReportMapper">
    <insert id="insert" parameterType="PostReportCreateRequestDTO">
        INSERT INTO TBL_POST_REPORT
        VALUES (SEQ_POST_REPORT.NEXTVAL, #{postReportContent}, CURRENT_TIMESTAMP, #{reportReasonCategoryId}, #{postId}, #{memberId})
    </insert>
</mapper>