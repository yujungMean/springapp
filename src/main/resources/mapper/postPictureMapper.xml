<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.app.springapp.mapper.PostPictureMapper">
    <select id="selectAll" parameterType="Long" resultType="String">
        SELECT POST_PICTURE_ADDRESS
        FROM TBL_POST_PICTURE
        WHERE POST_ID = #{id}
    </select>
</mapper>