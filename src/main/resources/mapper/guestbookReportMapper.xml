<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.app.springapp.mapper.GuestbookReportMapper">
    <insert id="insert" parameterType="GuestbookReportCreateRequestDTO">
        INSERT INTO TBL_GUESTBOOK_REPORT
        VALUES (SEQ_GUESTBOOK_REPORT.NEXTVAL, #{guestbookReportContent}, CURRENT_TIMESTAMP, #{memberId}, #{guestbookId}, #{reportReasonCategoryId})
    </insert>
</mapper>
