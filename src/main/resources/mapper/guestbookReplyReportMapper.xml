<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.app.springapp.mapper.GuestbookReplyReportMapper">
    <insert id="insert" parameterType="GuestbookReplyReportCreateRequestDTO">
        INSERT INTO TBL_GUESTBOOK_REPLY_REPORT
        VALUES (SEQ_GUESTBOOK_REPLY_REPORT.NEXTVAL, #{guestbookReplyReportContent}, CURRENT_TIMESTAMP, #{memberId}, #{guestbookReplyId}, #{reportReasonCategoryId})
    </insert>
</mapper>
