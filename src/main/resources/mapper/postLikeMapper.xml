<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.app.springapp.mapper.PostLikeMapper">
    <insert id="insert" parameterType="PostLikeRequestDTO">
        INSERT INTO TBL_POST_LIKE
        VALUES (SEQ_POST_LIKE.NEXTVAL, #{postId}, #{memberId})
    </insert>

    <delete id="delete" parameterType="PostLikeRequestDTO">
        DELETE FROM TBL_POST_LIKE
        WHERE POST_ID = #{postId} AND MEMBER_ID = #{memberId}
    </delete>

    <select id="selectLikeCountAndIsLiked" parameterType="PostLikeRequestDTO" resultType="PostLikeResponseDTO">
        SELECT
            COUNT(*)                                         AS LIKE_COUNT,
            MAX(CASE WHEN MEMBER_ID = #{memberId} THEN 1 ELSE 0 END)   AS IS_LIKED
        FROM TBL_POST_LIKE
        WHERE POST_ID = #{postId}
    </select>
</mapper>